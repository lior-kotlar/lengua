{
  "name": "api-types",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Generated TypeScript types + a typed client for the Lengua API, derived from apps/api/openapi.json.",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./constants": "./src/constants.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src"
  ],
  "scripts": {
    "generate": "openapi-typescript ../../apps/api/openapi.json --output ./src/schema.ts && node scripts/generate-constants.mjs",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.5"
  },
  "devDependencies": {
    "openapi-typescript": "^7.6.1",
    "typescript": "~5.6.3"
  }
}
