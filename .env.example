# Lengua environment variables — copy to .env and fill in real values.
# .env is gitignored; never commit real secrets.

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Switch providers with one env var — no code change needed.
# Default: groq (free tier, no card required). Flip to gemini for prod.
LLM_PROVIDER=groq

# Groq (default for all dev + CI — free tier, ~30 RPM / ~1K RPD)
# Get a key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here
# gemma2-9b-it was decommissioned by Groq; use a live model (verify at /openai/v1/models).
GROQ_MODEL=llama-3.1-8b-instant

# Gemini (set LLM_PROVIDER=gemini to activate — used for prod / prompt validation)
# Get a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Database ───────────────────────────────────────────────────────────────────
# Local: provided by `supabase start` (see supabase status after starting)
# Staging/Prod: from Supabase dashboard → Project Settings → Database → URI
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ── Supabase Auth ─────────────────────────────────────────────────────────────
# From Supabase dashboard → Project Settings → API
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your_anon_key_here
# Server-only secret (NEVER ship to the client). Used by the account-deletion path
# (DELETE /account) to hard-delete the auth user via the Supabase Auth Admin API.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# The backend verifies every access token against this. HS256 shared secret is the default
# (Project Settings → API → JWT Settings, or the local CLI's well-known dev secret).
SUPABASE_JWT_SECRET=your_jwt_secret_here
# Optional: set to verify asymmetric (RS256/ES256) "JWT signing keys" via JWKS instead of the
# shared secret — e.g. https://<project>.supabase.co/auth/v1/.well-known/jwks.json
# SUPABASE_JWKS_URL=
# Audience the backend requires in the token (Supabase signs access tokens with "authenticated").
# SUPABASE_JWT_AUD=authenticated

# ── CORS (task 6.10.1) ────────────────────────────────────────────────────────
# Allowlisted browser/app origins that may call the API cross-origin. Comma-separated; an unlisted
# origin gets no Access-Control-Allow-Origin. Defaults cover local web dev + the Capacitor app
# scheme. Set this PER ENVIRONMENT to EXACTLY the deployed web origins:
#   • staging → the staging Vercel URL(s) / custom domain(s)
#   • prod    → the prod web origin(s) ONLY — and the native app scheme(s) when mobile ships.
# NEVER use a wildcard ("*"). The API sends credentials (allow_credentials=True), so "*" is both
# insecure (any site could make credentialed calls) AND invalid per the Fetch spec — and the
# backend test suite (apps/api/tests/test_cors.py) fails on a wildcard in any environment.
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000,capacitor://localhost
# Prod example (exact origins, no wildcard):
# CORS_ALLOW_ORIGINS=https://lengua.vercel.app,https://app.lengua.example

# ── LLM cost guard (Phase 3) ──────────────────────────────────────────────────
# Per-user daily caps per LLM kind (generate / discover / explain). A user's own cap (set in
# user_settings: daily_cap_generate / daily_cap_discover / daily_cap_explain) is clamped by the
# hard server MAX below, so a user can never exceed the operator limit; the DEFAULT applies when a
# user has set no override. Defaults are conservative — raise per environment via these env vars.
MAX_GENERATE_PER_DAY=50          # hard ceiling on /generate calls per user per day
MAX_DISCOVER_PER_DAY=30          # hard ceiling on /discover calls per user per day
MAX_EXPLAIN_PER_DAY=100          # hard ceiling on /explain (cache-miss) calls per user per day
DEFAULT_GENERATE_PER_DAY=20      # per-user default /generate cap when no override is set
DEFAULT_DISCOVER_PER_DAY=10      # per-user default /discover cap when no override is set
DEFAULT_EXPLAIN_PER_DAY=50       # per-user default /explain cap when no override is set
# Per-user sliding-window rate limit (Phase 3.3): max gated LLM requests/min across ALL kinds. Over
# it, the API returns 429 {"code":"rate_limited"} with a Retry-After header. In-process today
# (single instance); the distributed (Postgres/Upstash) swap is a Phase-6 concern.
RATE_LIMIT_PER_MIN=10            # per-user requests/min across generate+discover+explain
# Signup-abuse day-0 guard (Phase 3.7): a brand-new account (created today, UTC) gets this reduced
# /generate ceiling for its first day — effective generate cap = min(resolved cap, this). Established
# accounts use their normal cap. (A signup CAPTCHA would slot in alongside this — not built.)
NEW_ACCOUNT_DAY0_GENERATE_CAP=5  # reduced /generate cap on an account's first day
# Global daily budget kill-switch (Phase 3.4): the project-wide ceiling on SUCCESSFUL LLM calls per
# day, summed across ALL users — the "I will never get a bill" backstop and the LAST quota gate. Once
# the global counter reaches this for the UTC day, every user gets HTTP 429
# {"code":"daily_limit_reached","message":"Daily limit reached, please try again tomorrow."} until the
# day rolls over. Set this BELOW the active provider's free-tier requests-per-day (RPD) ÷ max retry
# attempts (lengua_core/llm/retry.py DEFAULT_MAX_ATTEMPTS = 3): one counted call can fan out to up to
# 3 real provider HTTP requests on 429/5xx, so RPD/3 keeps the worst case under the free tier. Groq
# llama-3.1-8b-instant's free tier is on the order of a few thousand/day, so the default 1000 holds
# with margin (1000 × 3 = 3000 worst-case requests).
GLOBAL_DAILY_BUDGET=1000         # project-wide successful-LLM-call ceiling/day (< provider RPD ÷ 3)
# Global concurrency cap (Phase 3.5): the max number of provider (LLM) calls in flight across the
# whole process at once, enforced by a global asyncio semaphore. Each blocking provider call runs in
# a worker thread under this cap, so the event loop stays responsive and the free tier is never
# flooded. Over the cap a request waits briefly then gets HTTP 503 {"code":"server_busy",...} (with a
# short Retry-After) rather than queuing unbounded. This value is ALSO the hard bound on the global
# kill-switch's read-then-increment overshoot (the budget is read before a call and incremented after
# success, so concurrent in-flight requests can overshoot by at most this many). SCALE-OUT NOTE: this
# cap is per-process — making horizontal scale beyond 1 instance safe additionally requires the
# distributed rate limiter (Phase 6, app/ratelimit.py). Until both land, run a single API instance.
LLM_MAX_CONCURRENCY=4            # max concurrent in-flight provider calls (per process)
# Cost minimization (Phase 3.6) — the cheapest call is the one you don't make.
# MAX_WORDS_PER_REQUEST: hard ceiling on the vocabulary words a single /generate request may carry.
# Over it, POST /generate is rejected with HTTP 422 (a hard reject at the API boundary, NOT silent
# truncation) so an oversized prompt never reaches the provider. Bounds prompt size + cost.
MAX_WORDS_PER_REQUEST=30         # /generate word-list cap (also bounds prompt size); 422 if exceeded
# DISCOVER_REUSE_WINDOW_SECONDS: a repeated /discover for the same (user, language, topic, count)
# within this window returns the PRIOR preview from an in-process reuse cache — no fresh provider
# call and no daily-cap/budget count. In-process today (single instance); a repeat that lands on a
# different instance simply misses (makes a fresh, fully-gated call). The distributed
# (Redis/Upstash or a TTL Postgres table) swap is a Phase-6 concern (app/discover_cache.py seam) —
# the same single-instance-now caveat family as the in-process rate limiter.
DISCOVER_REUSE_WINDOW_SECONDS=300  # short /discover preview reuse window (seconds)

# ── Feature flags (Phase 6.9) ─────────────────────────────────────────────────
# Risky/new features ship DARK behind a flag (off by default) and can be toggled in prod WITHOUT a
# redeploy. Each KNOWN flag resolves from (1) its FEATURE_* env default below, overlaid by (2) a row
# in the global `feature_flags` table (name/enabled/updated_at). The table layer is the no-redeploy
# path: write the row and the app picks it up within FEATURE_FLAG_TTL_SECONDS. The table is GLOBAL
# operator config — locked down to the server (REVOKE from authenticated/anon + deny-by-default RLS);
# clients only ever read the resolved PUBLIC map via GET /feature-flags. Env defaults are off unless
# set to a truthy value (1/true/yes/on).
FEATURE_FLAG_TTL_SECONDS=30      # in-process cache TTL for the feature_flags table (0 = re-read each time)
# Experimental "word of the day" surface — ships dark; gates GET /experimental/word-of-the-day +
# the web card. Leave unset (off) in every environment until the feature is finished.
# FEATURE_WORD_OF_THE_DAY=false

# ── App Settings ──────────────────────────────────────────────────────────────
ENV=local          # local | staging | prod
# LENGUA_DB_PATH=data/lengua.db    # legacy SQLite path (Streamlit app only)
# LENGUA_DAILY_NEW_LIMIT=10
# LENGUA_DAILY_TOTAL_LIMIT=50

# ── Observability (fill in for staging/prod) ──────────────────────────────────
# deployment.environment resource tag stamped on every trace + metric (alongside
# service.name=lengua-api), so Grafana can filter signals per environment (task 5.1.1). Defaults to
# ENV above; set it explicitly only to override (allowed: local | staging | prod).
# DEPLOYMENT_ENVIRONMENT=staging
# OTLP export to Grafana Cloud (tasks 5.1.5 / 5.3.1). Setting OTEL_EXPORTER_OTLP_ENDPOINT enables
# trace (→ Grafana Cloud Tempo), metric (→ Mimir), AND log (→ Loki) OTLP export — the cost-guard
# spans/metrics from Phase 3.8 and the structured access/app log lines (correlated by trace_id) all
# included. Unset locally/CI → no-op, zero network egress. OTEL_EXPORTER_OTLP_HEADERS carries the
# Grafana Cloud auth token (HTTP Basic of "<instanceId>:<api-token>", base64-encoded); the exporter
# reads it itself. Use the signal-specific *_ENDPOINT vars to point a signal at a different collector
# (the stdout JSON access line is always emitted regardless — Cloud Run ships it to Loki too).
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-eu-west-2.grafana.net/otlp
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic base64(instanceId:token)
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=https://otlp-gateway-prod-eu-west-2.grafana.net/otlp
# OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=https://otlp-gateway-prod-eu-west-2.grafana.net/otlp
# Error tracking (task 5.4). The BACKEND Sentry DSN — Sentry is initialised only when this is set
# (app/error_tracking.py), a no-op with zero egress otherwise. The web app uses a SEPARATE,
# browser-safe DSN that MUST be VITE_-prefixed to reach the bundle — it lives in apps/web/.env as
# VITE_SENTRY_DSN_WEB (see apps/web/.env.example), NOT here.
# SENTRY_DSN_API=https://your_key@o0.ingest.de.sentry.io/0   # FastAPI backend
