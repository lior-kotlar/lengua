# apps/web environment (Vite build-time vars).
#
# Copy to `apps/web/.env` and fill in real values for local dev:
#   cp apps/web/.env.example apps/web/.env
#
# These are inlined into the bundle at build time, so only PUBLIC values belong here
# (the Supabase anon key is safe to ship to the browser; never put a service-role key here).
# The app validates these at config-load and FAILS FAST with a clear error naming any that are
# missing (see src/lib/env.ts) the moment Supabase/API access is needed — so a misconfigured
# deploy surfaces immediately instead of as a confusing runtime crash.

# Base URL of the Lengua FastAPI backend.
VITE_API_BASE_URL=http://localhost:8000

# Supabase project URL (auth only — all app data goes through the API, not Supabase data APIs).
VITE_SUPABASE_URL=http://localhost:54321

# Supabase anon/public key (auth only). Get it from `supabase status` (local) or the dashboard.
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# OPTIONAL — comma-separated OAuth providers to enable on the auth screens (sign-up + log-in).
# Defaults to "google,apple" when unset (both buttons rendered + actionable). Live OAuth
# credentials are OWNER-ONLY (Google client id/secret; Apple needs a paid Developer account — see
# infra/supabase/oauth-setup.md), so until they're wired a click surfaces a friendly error. To hide
# a provider behind a disabled "(soon)" button, narrow this list (e.g. "google") or set it empty.
# VITE_OAUTH_PROVIDERS=google,apple

# OPTIONAL — PostHog project key for EU-hosted (eu.i.posthog.com) product analytics (group 5.9).
# Analytics loads ONLY after the user opts in (the first-run consent banner / the Settings toggle)
# AND this key is set; posthog-js is then lazily code-split in. Leave unset for dev/CI/E2E — nothing
# analytics-related loads or is sent, even if the user opts in (a clean, key-gated seam).
# VITE_POSTHOG_KEY=phc_your_project_key

# OPTIONAL — browser Sentry DSN for JS error + performance/Web-Vitals tracking (task 5.4.2). Sentry
# initialises ONLY when this is set; unset → nothing loads, zero egress (the dev/CI/E2E path). This
# is the web app's OWN, browser-safe DSN — separate from the backend's SENTRY_DSN_API — and MUST be
# VITE_-prefixed to be inlined into the bundle (this RENAMES the old non-prefixed SENTRY_DSN_WEB).
# VITE_SENTRY_DSN_WEB=https://your_key@o0.ingest.de.sentry.io/0

# OPTIONAL — Sentry `environment` tag for this build (e.g. "staging" / "production"). Tags every
# event so issues filter by environment. Defaults to Vite's MODE when unset — but `vercel build`
# always reports MODE="production", so CD sets this explicitly per environment (see deploy-*.yml) to
# stop staging events mistagging as production. No effect unless VITE_SENTRY_DSN_WEB is also set.
# VITE_SENTRY_ENVIRONMENT=staging

# OPTIONAL — Sentry `tracesSampleRate` (a float in [0, 1]): the fraction of performance/Web-Vitals
# transactions sampled. Defaults to 1.0 (capture everything) when unset; CD sets ~0.1 for prod to cap
# transaction volume/cost. No effect unless VITE_SENTRY_DSN_WEB is also set.
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# OPTIONAL — dev/test only. NEVER set this in a production build. When set ("1"/"true") it renders a
# hidden Sentry debug-error button (and records captures on window for the E2E assertion). The
# Playwright E2E build sets it; a production deploy must leave it unset so the button can't appear.
# VITE_ENABLE_DEBUG_TOOLS=1
