# apps/web environment (Vite build-time vars).
#
# Copy to `apps/web/.env` and fill in real values for local dev:
#   cp apps/web/.env.example apps/web/.env
#
# These are inlined into the bundle at build time, so only PUBLIC values belong here
# (the Supabase anon key is safe to ship to the browser; never put a service-role key here).
# The app validates these at config-load and FAILS FAST with a clear error naming any that are
# missing (see src/lib/env.ts) the moment Supabase/API access is needed — so a misconfigured
# deploy surfaces immediately instead of as a confusing runtime crash.

# Base URL of the Lengua FastAPI backend.
VITE_API_BASE_URL=http://localhost:8000

# Supabase project URL (auth only — all app data goes through the API, not Supabase data APIs).
VITE_SUPABASE_URL=http://localhost:54321

# Supabase anon/public key (auth only). Get it from `supabase status` (local) or the dashboard.
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
