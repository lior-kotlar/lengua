{
  "uid": "lengua-service-health",
  "title": "Lengua — Service health (RED)",
  "description": "Request rate, error rate, and p50/p95/p99 latency per route, derived from the FastAPI server request-duration histogram (task 5.2.6). Dashboards-as-code: import or provision per environment; the Prometheus/Mimir data source is selected by the ${datasource} variable. See infra/grafana/README.md for the metric-name policy.",
  "tags": ["lengua", "red", "service-health"],
  "editable": true,
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "annotations": { "list": [] },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Prometheus / Mimir data source",
        "type": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "hide": 0,
        "current": {},
        "options": []
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate per route (req/s)",
      "description": "Per-route request rate from the request-duration histogram count series.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (http_target) (rate(http_server_duration_milliseconds_count[$__rate_interval]))",
          "legendFormat": "{{http_target}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error rate per route — 5xx (req/s)",
      "description": "Per-route rate of 5xx responses.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (http_target) (rate(http_server_duration_milliseconds_count{http_status_code=~\"5..\"}[$__rate_interval]))",
          "legendFormat": "{{http_target}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error ratio (5xx / all)",
      "description": "Fraction of requests returning 5xx over the dashboard window.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(http_server_duration_milliseconds_count{http_status_code=~\"5..\"}[$__rate_interval])) / clamp_min(sum(rate(http_server_duration_milliseconds_count[$__rate_interval])), 1)",
          "legendFormat": "5xx ratio"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99 (all routes)",
      "description": "Overall request-duration quantiles from the histogram buckets.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 0 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_duration_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_duration_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_duration_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "p95 latency per route",
      "description": "p95 request duration broken out per route — surfaces a slow endpoint (e.g. /generate vs /review).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 0 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le, http_target) (rate(http_server_duration_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "{{http_target}}"
        }
      ]
    }
  ]
}
